# --- Access token (optional override) ---
# On first run the app asks for your token and stores it under the
# user's state dir. Set LICENSE_KEY here only to force a specific token
# (e.g. headless / CI). Leave blank otherwise.
LICENSE_KEY=

# --- Email domains used for randomly generated addresses ---
EMAIL_DOMAINS=example.com,example.org

# --- Captcha solver ---
CAPSOLVER_API_KEY=
# Seconds to wait for a captcha solution.
CAPSOLVER_TIMEOUT=180

# --- DataImpulse proxy (optional) ---
# Set PROXY_ENABLED=true to route upstream traffic through DataImpulse.
PROXY_ENABLED=false
DATAIMPULSE_USERNAME=
DATAIMPULSE_PASSWORD=
# Default DataImpulse gateway
DATAIMPULSE_HOST=gw.dataimpulse.com
DATAIMPULSE_PORT=823
# Optional ISO country code and sticky session id.
# Example: DATAIMPULSE_COUNTRY=mx
DATAIMPULSE_COUNTRY=
DATAIMPULSE_SESSION=
