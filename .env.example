EMAIL_DOMAINS=example.com,example.org

# CapSolver API key (https://dashboard.capsolver.com)
CAPSOLVER_API_KEY=

# Optional: timeout (detik) untuk menunggu solusi captcha
CAPSOLVER_TIMEOUT=180

# === DataImpulse Proxy (opsional) ===
# Set PROXY_ENABLED=true untuk mengaktifkan proxy.
PROXY_ENABLED=false
DATAIMPULSE_USERNAME=
DATAIMPULSE_PASSWORD=
# Default gateway DataImpulse
DATAIMPULSE_HOST=gw.dataimpulse.com
DATAIMPULSE_PORT=823
# Optional: target country (ISO code) dan session sticky id
# Contoh: DATAIMPULSE_COUNTRY=mx
DATAIMPULSE_COUNTRY=
DATAIMPULSE_SESSION=
