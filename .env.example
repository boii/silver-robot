# =====================================================================
#  GPT Promo Grabber  -  by @putrm
#  Need a license key? Buy one at https://t.me/putrm
# =====================================================================

# --- License (optional override) ---
# On first run the app asks for your license key and saves it under
# ~/.config/gptcode/license.key. Subsequent runs reuse it silently.
# Set LICENSE_KEY here only if you want to force a specific key, e.g. in
# headless / CI setups. Leave it blank otherwise.
LICENSE_KEY=

# --- Email domains used for randomly generated addresses ---
EMAIL_DOMAINS=example.com,example.org

# --- CapSolver (https://dashboard.capsolver.com) ---
CAPSOLVER_API_KEY=
# Seconds to wait for a captcha solution.
CAPSOLVER_TIMEOUT=180

# --- DataImpulse proxy (optional) ---
# Set PROXY_ENABLED=true to route upstream traffic through DataImpulse.
PROXY_ENABLED=false
DATAIMPULSE_USERNAME=
DATAIMPULSE_PASSWORD=
# Default DataImpulse gateway
DATAIMPULSE_HOST=gw.dataimpulse.com
DATAIMPULSE_PORT=823
# Optional ISO country code and sticky session id.
# Example: DATAIMPULSE_COUNTRY=mx
DATAIMPULSE_COUNTRY=
DATAIMPULSE_SESSION=
